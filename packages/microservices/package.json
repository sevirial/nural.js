{
  "name": "@nuraljs/microservices",
  "version": "0.6.2",
  "description": "A lightweight, highly extensible RPC and Message Broker microservices module for the Nural.js framework.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "MIGRATION.md",
    "RELIABILITY.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nuraljs",
    "microservices",
    "rpc",
    "messaging",
    "zod"
  ],
  "author": {
    "name": "Chetan Joshi",
    "email": "chetanjoshi707@gmail.com",
    "url": "https://github.com/ErrorX407"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sevirial/nural.js.git",
    "directory": "packages/microservices"
  },
  "bugs": {
    "url": "https://github.com/sevirial/nural.js/issues"
  },
  "homepage": "https://nuraljs.org",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nuraljs/core": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^4.0.0",
    "amqplib": "^0.10.9",
    "ioredis": "^5.10.0",
    "kafkajs": "^2.2.4"
  },
  "peerDependenciesMeta": {
    "amqplib": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "kafkajs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "amqplib": "^0.10.9",
    "eslint": "^8.57.0",
    "ioredis": "^5.10.0",
    "kafkajs": "^2.2.4",
    "prettier": "^3.2.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "sideEffects": false
}
