{
  "name": "@nuraljs/core",
  "version": "1.0.1",
  "description": "The intelligent, schema-first REST framework for Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rest",
    "api",
    "framework",
    "zod",
    "typescript",
    "schema",
    "openapi"
  ],
  "author": {
    "name": "Chetan Joshi",
    "email": "chetanjoshi707@gmail.com",
    "url": "https://github.com/ErrorX407"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sevirial/nural.js.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/sevirial/nural.js/issues"
  },
  "homepage": "https://nuraljs.org",
  "peerDependencies": {
    "express": "^5.2.1",
    "fastify": "^5.7.4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fast-json-stringify": "^7.0.1",
    "socket.io": "^4.8.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.1",
    "fastify": "^5.7.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
