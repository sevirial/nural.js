{
  "name": "@nuraljs/cli",
  "version": "1.0.0",
  "description": "CLI for Nuraljs Framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nural": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest"
  },
  "keywords": [
    "nuraljs",
    "cli",
    "framework",
    "rest",
    "api"
  ],
  "author": "Chetan Joshi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sevirial/nural.js.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/sevirial/nural.js/issues"
  },
  "homepage": "https://nuraljs.org",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.14",
    "ora": "^8.0.1",
    "prettier": "^3.9.5",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nuraljs/auth": ">=0.6.0"
  },
  "peerDependenciesMeta": {
    "@nuraljs/auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuraljs/auth": "workspace:*",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.24",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
