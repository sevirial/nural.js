import { createModule } from "@nuraljs/core";
import * as <%= className %>Controller from "./<%= fileName %>.controller";

export const <%= camelName %>Module = createModule({
  prefix: "/<%= fileName %>s",
  tags: ["<%= className %>"],
  // Register every route the controller exports. Importing the module as a
  // namespace means renaming, adding, or removing a handler needs no edit
  // here — no hardcoded handler names to drift out of sync (avoids TS2724).
  routes: Object.values(<%= className %>Controller),
});
