import { app<% if (integrations.includes('ws')) { %>, attachSockets<% } %> } from "./app";
import { env } from "./config/env";
<% if (integrations.includes('rabbitmq')) { -%>
import { rabbitMqProvider } from "./providers/rabbitmq";
<% } -%>
<% if (integrations.includes('mongoose')) { -%>
import { mongooseProvider } from "./providers/mongoose";
<% } -%>
<% if (integrations.includes('prisma-pg')) { -%>
import { prismaProvider } from "./providers/prisma";
<% } -%>
<% if (integrations.includes('redis')) { -%>
import { redisProvider } from "./providers/redis";
<% } -%>

async function bootstrap() {
<% if (integrations.includes('rabbitmq')) { -%>
  await app.registerProvider(rabbitMqProvider);
<% } -%>
<% if (integrations.includes('mongoose')) { -%>
  await app.registerProvider(mongooseProvider);
<% } -%>
<% if (integrations.includes('prisma-pg')) { -%>
  await app.registerProvider(prismaProvider);
<% } -%>
<% if (integrations.includes('redis')) { -%>
  await app.registerProvider(redisProvider);
<% } -%>
<% if (integrations.includes('ws')) { -%>
  const server = app.start(Number(env.PORT));

  // Attach Socket.io
  attachSockets(server);
  console.log("🔌 WebSockets enabled");
<% } else { -%>
  app.start(Number(env.PORT));
<% } -%>
}

bootstrap();
