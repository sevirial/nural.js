import Redis from 'ioredis';
import { defineProvider } from '@nuraljs/core';
import { env } from '../config/env';

export const redis = new Redis(env.REDIS_URL, { lazyConnect: true });

export const redisProvider = defineProvider({
  name: 'Redis',
  setup: async () => {
    await redis.connect();
    console.log('📦 Redis connected');
    return redis;
  },
  teardown: async (instance) => {
    instance.disconnect();
  }
});
