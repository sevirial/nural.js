import { PrismaClient } from "@prisma/client";
import { PrismaPg } from "@prisma/adapter-pg";
import { defineProvider } from "@nuraljs/core";
import pg from "pg";
import { env } from "../config/env";

const connectionString = env.DIRECT_DATABASE_URL ?? env.DATABASE_URL;

const pool = new pg.Pool({ connectionString });
const adapter = new PrismaPg(pool);

export const prisma = new PrismaClient({ adapter });

export const prismaProvider = defineProvider({
  name: "Prisma",
  setup: async () => {
    await prisma.$connect();
    console.log("🐘 Prisma connected (v7 Adapter)");
    return prisma;
  },
  teardown: async (instance) => {
    await instance.$disconnect();
  }
});
